{
  "name": "hirex-api",
  "version": "1.0.0",
  "description": "HireX — AI Recruitment Platform API",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "bun --env-file=.env drizzle-kit push",
    "test": "bun test src/tests --timeout 15000"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.2.2",
    "@neondatabase/serverless": "^0.9.3",
    "@sentry/node": "^10.59.0",
    "argon2": "^0.40.3",
    "axios": "^1.7.2",
    "bullmq": "^5.8.0",
    "cloudinary": "^2.3.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.31.2",
    "hono": "^4.4.0",
    "ioredis": "^5.4.1",
    "jose": "^5.6.3",
    "postgres": "^3.4.4",
    "resend": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.22.7",
    "typescript": "^5.4.5"
  }
}
